# Backend API URL
# The Express server running the orchestrator and serving REST endpoints
# Default: http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Goldsky GraphQL Endpoint
# Indexer for KitexAuditLog events and Algebra pool events
# Example: https://api.goldsky.com/api/public/project_XXXXX/subgraphs/kitex-kite-ai/1.0.0/gn
NEXT_PUBLIC_GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/project_cmot2ezts01ox01vf2zo90141/subgraphs/kitex-kite-ai/1.0.0/gn

# Optional: Enable debug logging
# NEXT_PUBLIC_DEBUG=true
