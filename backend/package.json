{
  "name": "kitex-backend",
  "version": "1.0.0",
  "description": "Kitex backend — Express server, agent orchestrator, Goldsky + Kite Passport integration",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "orchestrator": "ts-node-dev --respawn --transpile-only orchestrator/run.ts",
    "test:cycle": "ts-node tests/cycle.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.0",
    "graphql-request": "^6.1.0",
    "mongodb": "^6.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
