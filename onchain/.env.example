# Deployer wallet - the wallet that pays gas for contract deployment
PRIVATE_KEY=your_private_key_here

# Kite Mainnet
KITE_RPC_URL=https://rpc.gokite.ai/
KITE_CHAIN_ID=2368

# Kitescan - for contract verification after deploy
KITESCAN_API_KEY=your_kitescan_api_key_here

# Filled in AFTER deployment - leave blank until contracts are deployed
CAPITAL_ROUTER_ADDRESS=
AUDIT_LOG_ADDRESS=

# Bundler - for session key / gasless tx (used by backend later)
BUNDLER_RPC=https://bundler-service.staging.gokite.ai/rpc/

# Goldsky - for subgraph deployment
GOLDSKY_PROJECT_ID=your_goldsky_project_id_here

# Agent DIDs (bytes32) - used in CapitalRouter.registerAgent() and backend
LIQUIDITY_AGENT_DID=0x4c69717569646974794167656e74000000000000000000000000000000000000
ARB_AGENT_DID=0x4172626974726167654167656e74000000000000000000000000000000000000
RISK_AGENT_DID=0x5269736b4167656e740000000000000000000000000000000000000000000000

# Kite Passport
PASSPORT_AGENT_ID=agent_019df9c2-f07b-7845-a15a-1bb1b8c3b726
PASSPORT_OWNER_ID=user_019df9c0-e372-7331-ab73-867b128df928
